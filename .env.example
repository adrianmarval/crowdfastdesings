# ==========================================
# Base de Datos (Database)
# ==========================================
# Credenciales de conexión a la base de datos
DB_USER=          # Nombre de usuario de la base de datos
DB_NAME=          # Nombre de la base de datos
DB_PASSWORD=      # Contraseña del usuario de la base de datos

# URL de conexión completa proporcionada por tu proveedor (ej. Vercel Postgres, Supabase, Neon, Render, Localhost)
# Formato típico: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# ==========================================
# Aplicación (App)
# ==========================================
# La URL base donde se ejecuta la aplicación
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.com
NEXT_PUBLIC_APP_URL=

# ==========================================
# Autenticación (Better Auth)
# ==========================================
# Secreto utilizado para firmar tokens y cookies por seguridad.
# Puedes generar uno nuevo ejecutando en la terminal: npx @better-auth/cli generate secret
# O también usando OpenSSL: openssl rand -base64 32
BETTER_AUTH_SECRET=

# La URL de tu aplicación para Better Auth. Usualmente la misma que NEXT_PUBLIC_APP_URL.
# En desarrollo: http://localhost:3000
BETTER_AUTH_URL=

# ==========================================
# Correos Electrónicos (Resend)
# ==========================================
# API Key para enviar correos transaccionales (ej. recibos, notificaciones).
# Se obtiene creando una cuenta en Resend (https://resend.com) -> API Keys.
RESEND_API_KEY=

# ==========================================
# Pasarela de Pagos (PayPal)
# ==========================================
# Se obtienen creando una App en el portal de PayPal Developer (https://developer.paypal.com/dashboard/applications)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=  # Client ID público (Sandbox o Producción)
PAYPAL_SECRET=                 # Secret Key privado (Sandbox o Producción)

# Endpoints de la API de PayPal (Por defecto apuntan a Sandbox para pruebas).
# Para producción, cambia "api-m.sandbox" por "api-m" y "api.sandbox" por "api".
# Endpoint de OAuth (POST) para obtener tokens:
PAYPAL_OAUTH_URL=https://api-m.sandbox.paypal.com/v1/oauth2/token
# Endpoint de Órdenes (GET/POST) para procesar pagos:
PAYPAL_ORDERS_URL=https://api.sandbox.paypal.com/v2/checkout/orders

# ==========================================
# Backend / Almacenamiento (Appwrite)
# ==========================================
# Se obtienen del panel de control de tu proyecto en Appwrite Cloud (https://cloud.appwrite.io/) o tu instancia autoalojada.

# --- Público para los componentes (frontend) ---
NEXT_PUBLIC_APPWRITE_PROJECT_ID=        # ID único de tu proyecto en Appwrite (Settings > Project ID)
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=      # Nombre del proyecto en Appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT=          # En cloud suele ser: https://cloud.appwrite.io/v1

# Buckets de Storage (Almacenamiento de archivos)
# ID del Bucket creado en Appwrite para guardar las imágenes visibles de los productos (debe tener permisos públicos de lectura)
NEXT_PUBLIC_APPWRITE_IMAGES_BUCKET=

# --- Privado para el Seed y Server Actions (Seguridad) ---
# ID del Bucket creado para archivos confidenciales o ZIPS de los productos digitales.
# Los permisos de lectura de este bucket NO deben ser públicos ('any'), solo accesibles mediante la API Key del lado del servidor.
APPWRITE_ZIPS_BUCKET=

# API Key de Appwrite con permisos elevados para operaciones en el backend.
# Se crea en Appwrite: Project > Overview > Integrations > API Keys. 
# Asegúrate de habilitar los "Scopes" necesarios para Storage (archivos) y Databases (bases de datos).
APPWRITE_API_KEY=